{{ define "repo-log-ref" -}}
<!DOCTYPE html>
<html lang="en">
	<head>
		{{ template "head" }}
		<link rel="stylesheet" href="/static/repo-log-ref.css" />
		<title>
			Commit history at {{ .Meta.Ref }} - {{ .Meta.DisplayName }}
		</title>
		<meta name="description" content='Commit history on {{ .Meta.DisplayName }} at {{ .Meta.Ref }}' />
		<script type="module" src="/static/convert-to-local-datetime.js"></script>
	</head>
	<body>
		<header class="header">
			<ol class="breadcrumbs">
				<li>
					<a href="/">Top</a>
				</li>
				<li>
					<a href="/{{ .Meta.DirName }}">{{ .Meta.DisplayName }}</a>
				</li>
				<li>
					<a href="/{{ .Meta.DirName }}/log/{{ .Meta.Ref }}" aria-current="page">
						Commits
					</a>
				</li>
			</ol>
			{{ template "repo-header" . }}
			{{ template "repo-nav" . }}
		</header>
		<main class="main">
			<h1 class="log-heading">Commits at {{ .Meta.Ref }}</h1>
			<ol class="log-list">
				{{- $meta := .Meta -}}
				{{ range .Commits -}}
				<li id="commit-{{ .Hash.String }}" class="commit-summary">
					<a class="commit-summary--hash" href="/{{ $meta.DirName }}/commit/{{ .Hash.String }}">
						{{- slice .Hash.String 0 8 -}}
					</a>
					<span class="commit-summary--message" title="{{- .Message -}}">
						{{- .Message -}}
					</span>
					<span class="commit-summary--author">
						<a href="mailto:{{ .Author.Email }}">
							{{- .Author.Name -}}
						</a>
						authored at
						<time
							datetime='{{ .Author.When.Format "2006-01-02T15:04:05-0700" }}'
							data-local-format=""
						>
							{{ .Author.When.Format "2006-01-02 15:04:05 -0700" }}
						</time>
					</span>
					<span class="commit-summary--committer">
						<a href="mailto:{{ .Committer.Email }}">
							{{- .Committer.Name -}}
						</a>
						comitted at
						<time
							datetime='{{ .Committer.When.Format "2006-01-02T15:04:05-0700" }}'
							data-local-format=""
						>
							{{ .Committer.When.Format "2006-01-02 15:04:05 -0700" }}
						</time>
					</span>
				</li>
				{{- end }}
			</ol>
		</main>
		<aside class="aside">
			<div class="aside-contents">
				<dl class="metadata">
					<dt class="metadata--key">Commits for</dt>
					<dd class="metadata--value">{{ .Meta.Ref }}</dd>
					<dt class="metadata--key">Viewing range</dt>
					<dd class="metadata--value">
						{{- $top := .TopCommitForRange -}}
						{{- $bottom := .BottomCommitForRange -}}
						{{- if ne $top nil }}
							<a href="#commit-{{ $top.Hash }}">{{ slice $top.Hash.String 0 8 }}</a>
						{{- end -}}
						{{- if ne $bottom nil }}
							~ <a href="#commit-{{ $bottom.Hash }}">{{ slice $bottom.Hash.String 0 8 }}</a>
						{{- end -}}
					</dd>
				</dl>
				<div class="log-pagenav">
					{{- if ne .PrevPageHref "" }}
						<a href="{{ .PrevPageHref }}">&lt; Previous</a>
					{{- end -}}
					{{- if ne .NextPageHref "" }}
						<a href="{{ .NextPageHref }}">Next &gt;</a>
					{{- end -}}
				</div>
			</div>
		</aside>
		{{ template "site-footer" . }}
	</body>
</html>
{{- end }}
